    {
      "id": "player-controller",
      "status": "ported",
      "summary": "Phaser Kirdy movement constants and direct Matter velocity writes are replaced by a Godot CharacterBody2D controller with tuning resource, acceleration/deceleration, jump buffer, coyote time, jump cut, gravity split, hover, and trace events.",
      "godot_evidence": [
        "godot/scripts/player/PlayerController.gd",
        "godot/scripts/player/PlayerTuning.gd",
        "godot/levels/controller_lab.tscn",
        "godot/tests/replays/controller_lab_jump.json"
      ],
      "docs_evidence": [
        "docs/godot-v2/controller-lab.md"
      ],
      "validation": [
        "npm run godot:replay-suite",
        "npm test"
      ],
      "retirement_blocker": false
    },
