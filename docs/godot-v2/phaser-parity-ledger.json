    {
      "id": "export-packaging",
      "status": "ported",
      "summary": "The canonical build command now uses the Godot Web export wrapper, validates the Web export preset, and writes public deployment output to dist/index.html. Local builds skip gracefully when export templates are unavailable, while CI uses build:public so GitHub Pages never falls back to Phaser/Vite output.",
      "godot_evidence": [
        "godot/export_presets.cfg",
        "scripts/export-godot.mjs",
        ".github/workflows/test.yml"
      ],
      "docs_evidence": [
