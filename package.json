{
  "name": "fake-kirdy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run godot:run --",
    "godot:run": "node scripts/run-godot.mjs",
    "godot:replay": "node scripts/run-godot-replay.mjs",
    "godot:replay-suite": "node scripts/run-godot-replay-suite.mjs",
    "godot:performance": "node scripts/check-godot-performance.mjs",
    "godot:web-performance": "node scripts/check-godot-web-performance.mjs",
    "godot:web-smoke": "node scripts/check-godot-web-smoke.mjs",
    "godot:web-fallback": "node scripts/install-godot-web-fallback.mjs",
    "godot:usability": "node scripts/check-godot-usability.mjs",
    "godot:doctor": "node scripts/check-godot-doctor.mjs",
    "godot:scene-lint": "node scripts/check-godot-scene-lint.mjs",
    "godot:level-graph": "node scripts/check-godot-level-graph.mjs",
    "godot:progression-solver": "node scripts/check-godot-progression-solver.mjs",
    "godot:trace-assert": "node scripts/assert-godot-trace.mjs",
    "godot:replay-gen": "node scripts/generate-godot-replays.mjs",
    "godot:combat-matrix": "node scripts/check-godot-combat-matrix.mjs",
    "godot:enemy-ai-arena": "node scripts/check-godot-enemy-ai-arena.mjs",
    "godot:feel-metrics": "node scripts/check-godot-feel-metrics.mjs",
    "godot:visual-snapshot": "node scripts/check-godot-visual-snapshot.mjs",
    "godot:audio-audit": "node scripts/check-godot-audio-audit.mjs",
    "godot:content-budget": "node scripts/check-godot-content-budget.mjs",
    "godot:asset-fallback-audit": "node scripts/check-godot-asset-fallback-audit.mjs",
    "godot:save-load-roundtrip": "node scripts/check-godot-save-load-roundtrip.mjs",
    "godot:playtest-report": "node scripts/generate-godot-playtest-report.mjs",
    "godot:quality-report": "node scripts/generate-godot-quality-report.mjs",
    "godot:export": "node scripts/export-godot.mjs",
    "godot:export:web": "node scripts/export-godot.mjs --preset=Web --out=dist/index.html",
    "build:godot": "npm run godot:export:web --",
    "build:public": "npm run godot:export:web -- --clean --require-export",
    "build": "npm run build:godot --",
    "test": "npm run check:typecheck && npm run check:test && npm run check:godot",
    "test:canonical": "npm test && npm run godot:replay-suite --",
    "legacy:inventory": "node scripts/legacy-inventory.mjs",
    "godot:stage-manifest": "node scripts/check-godot-stage-manifest.mjs",
    "godot:procedural-levels": "node scripts/generate-godot-procedural-levels.mjs",
    "godot:catalog": "node scripts/generate-godot-level-catalog.mjs",
    "godot:content-check": "node scripts/check-godot-content-migration.mjs",
    "check:godot": "npm run godot:stage-manifest -- --check && npm run godot:procedural-levels -- --check && npm run godot:catalog -- --check && npm run godot:content-check && npm run godot:scene-lint && npm run godot:level-graph && npm run godot:progression-solver && npm run godot:combat-matrix && npm run godot:enemy-ai-arena && npm run godot:feel-metrics && npm run godot:visual-snapshot && npm run godot:audio-audit && npm run godot:content-budget && npm run godot:asset-fallback-audit && npm run godot:save-load-roundtrip && npm run godot:web-smoke && npm run godot:playtest-report -- --check && npm run godot:quality-report -- --check && npm run godot:replay-gen -- --check && npm run godot:export -- --check && node scripts/check-godot.mjs",
    "check:godot:runtime": "npm run godot:doctor -- --require-godot --skip-export-templates && npm run godot:save-load-roundtrip -- --runtime && npm run godot:replay-suite -- && npm run godot:trace-assert",
    "check:full": "npm run check:godot && npm run check:godot:runtime && npm run build:public && npm run godot:web-smoke -- --require-export --require-browser && npm run godot:web-performance",
    "check:test": "vitest run test/godot*.test.ts test/trace-summary.test.ts",
    "check:typecheck": "tsc --noEmit",
    "trace:summary": "node scripts/trace-summary.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.12.7",
    "jsdom": "^27.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
